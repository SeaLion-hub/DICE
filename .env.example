# PostgreSQL 연결 URL
# Railway에서 Postgres 플러그인을 추가하면 자동으로 발급됨.
# 로컬 실행 시 수동 입력 필요
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/<dbname>

# JWT 서명용 시크릿 키
# 꼭 충분히 긴 랜덤 문자열로 설정해야 함 (예: openssl rand -hex 32)
JWT_SECRET_KEY=your_secret_key_here

# Apify API 토큰 (선택)
# Apify 크롤러를 사용할 경우에만 필요
APIFY_TOKEN=your_apify_token_here
